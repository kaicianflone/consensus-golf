{
  "name": "consensus-research-sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run test/unit/",
    "test:integration": "vitest run test/integration/",
    "test:watch": "vitest",
    "cycle": "tsx src/cli/run-cycle.ts",
    "board": "tsx src/cli/show-board.ts",
    "precedents": "tsx src/cli/show-precedents.ts",
    "check-setup": "tsx src/cli/check-setup.ts",
    "build:deps": "cd packages/consensus-tools && pnpm install && pnpm -r --filter @consensus-tools/schemas --filter @consensus-tools/guards --filter @consensus-tools/core build",
    "prebuild": "npm run build:deps"
  },
  "packageManager": "pnpm@10.32.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@consensus-tools/core": "workspace:*",
    "@consensus-tools/schemas": "workspace:*",
    "ulid": "^3.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
